rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // OPTION 1: USER-AUTHENTICATED ACCESS (Recommended for Production)
    // Only logged-in users can read or write documents.
    // Use this rule if you implement Firebase Authentication.
    // ==========================================
    /*
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    */

    // ==========================================
    // OPTION 2: OPEN COLLECTION permissions (Recommended for prototyping/public sandbox)
    // Allows public read/write to the specific collections used by the application,
    // ensuring updates and deletes work perfectly without strict schema crashes.
    // ==========================================
    
    match /tasks/{taskId} {
      allow read, write: if true;
    }

    match /decisions/{decisionId} {
      allow read, write: if true;
    }

    match /blockers/{blockerId} {
      allow read, write: if true;
    }

    match /team/{memberId} {
      allow read, write: if true;
    }

    match /current_user/{activeState} {
      allow read, write: if true;
    }
  }
}
